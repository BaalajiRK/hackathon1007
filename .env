# --- Embedding backend ---
# "huggingface" = free, local, no API key (default)
# "openai"      = uses OpenAI text-embedding-3-small, requires OPENAI_API_KEY
EMBEDDING_BACKEND=huggingface
HF_EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- LLM (used for query rewriting, grading, and generation) ---
OPENAI_API_KEY='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'
LLM_MODEL=gpt-4o-mini

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=support_kb

# --- Agentic RAG tuning ---
# Minimum number of chunks graded "relevant" before the agent will generate
# an answer instead of escalating to a human.
MIN_RELEVANT_CHUNKS=1

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:3000
